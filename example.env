# jig-mcp environment configuration
# Copy to .env and uncomment/edit as needed.

# === Authentication ===

# Single shared token (simple setup — all clients share one identity):
# JIG_AUTH_TOKEN=your-secret-token-here

# Named tokens (multi-agent / multi-user — each client gets its own identity):
# Format: name1:token1,name2:token2
# The name appears in audit logs so you can tell who did what.
# JIG_AUTH_TOKENS=homelab-agent:tok_abc123,research-agent:tok_def456

# If both are set, JIG_AUTH_TOKENS takes precedence.
# If neither is set, SSE/dashboard endpoints are unauthenticated (fine for stdio-only).

# === Server Defaults ===

# JIG_TRANSPORT=stdio               # Transport mode: "stdio" or "sse"
# JIG_SSE_PORT=3001                 # Port for SSE transport
# JIG_TOOL_TIMEOUT=30s              # Default timeout for all tools (e.g. 30s, 1m, 5m)
# JIG_MAX_CONCURRENT_TOOLS=8        # Max simultaneous tool executions (default: min(NumCPU, 8))

# === Config Directory ===

# JIG_CONFIG_DIR=~/.jig-mcp         # Directory containing tools/ and scripts/
                                    # Default: auto-detect from binary location
                                    # Override with -config-dir flag (takes precedence)

# === Logging ===

# JIG_LOG_LEVEL=info                # Log level: debug, info, warn, error
# JIG_LOG_DIR=logs                  # Directory for audit logs
# JIG_LOG_MAX_SIZE_MB=50            # Max audit log size before rotation
# JIG_LOG_MAX_FILES=3               # Number of rotated audit logs to keep
# JIG_LOG_FILE_PERMS=0600           # File permissions for audit logs (e.g., 0600, 0644)

# === Unified Web Search ===
# Configure one search endpoint - works with SearXNG, Ollama, or any compatible API
# The same tool adapts to different providers based on these settings.

# Endpoint URL (required)
# SearXNG example: http://localhost:8080/search
# Ollama example: https://ollama.com/api/web_search
# SEARCH_ENDPOINT=http://localhost:8080/search

# HTTP method (required)
# SearXNG: GET
# Ollama: POST
# SEARCH_METHOD=GET

# API key (optional - leave empty for no auth)
# Ollama: Get from https://ollama.com/settings/keys
# SearXNG: Leave empty (no auth required)
# SEARCH_API_KEY=your_api_key_here

# Allowed URL prefixes for SSRF protection (recommended for remote instances)
# Comma-separated list of allowed URL prefixes
# Example: SEARCH_ALLOWED_PREFIXES=http://localhost:8080,https://ollama.com
# SEARCH_ALLOWED_PREFIXES=http://localhost:8080

# Response format (optional)
# SearXNG: json
# SEARCH_FORMAT=json

# Content-Type header (optional, defaults to application/json)
# SEARCH_CONTENT_TYPE=application/json
